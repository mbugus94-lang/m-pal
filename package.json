{
  "name": "m-pal",
  "version": "1.0.0",
  "description": "The unified SDK for African mobile money payments. M-Pesa, MTN MoMo, Airtel Money — one clean API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "docs:generate": "typedoc --out docs src",
    "prepare": "npm run build"
  },
  "keywords": ["africa", "mpesa", "mtn-momo", "airtel-money", "fintech", "kenya", "payments", "mobile-money"],
  "author": "Made in Nairobi 🇰🇪 by devs for Africa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbugus94-lang/m-pal.git"
  },
  "bugs": {
    "url": "https://github.com/mbugus94-lang/m-pal/issues"
  },
  "homepage": "https://github.com/mbugus94-lang/m-pal#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "dotenv": "^17.3.1",
    "p-queue": "^9.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
